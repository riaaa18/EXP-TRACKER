#include<iostream>
#include<fstream>
#include<string>
using namespace std;
struct exp{
    int week;
    double food, transport, entertainment, utility;
    char category[100][100];
    double amount[100];
}Expense[100];
int main()
{
    int week;
    char choice;
   cout<<"Enter the week number: ";
   cin>>week;
   for(int i=0;i<week;i++)
   {
    cout<<"Food :";
    cin>>Expense.food;
    cout<<"Transport :";
    cin>>Expense.transport;
    cout<<"Entertainment :";
    cin>>Expense.entertainment;
    cout<<"Utility :";
    cin>>Expense.utility;
    cout<<"Do you want to add custom category? (y/n): ";
    cin>>choice;
    if (choice=='y'|| choice=='Y')
    {
        cout<<"Enter the category name: ";
        cin>>Expense.category[i];
        cout<<"Enter the amount: ";
        cin>>Expense.amount[i];
    }
    else
    {
        cout<<"No custom category added."<<endl;
    }

    return 0;
}